# EkstreHub – Example environment variables
# Copy this file to .env and fill in your values.
# In Home Assistant add-on mode these are set automatically.

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────
# SQLite (development — auto-created in project root)
DB_URL=sqlite:///./dev-local.db

# PostgreSQL (production Docker Compose)
# DB_URL=postgresql://ekstrehub:ekstrehub@db:5432/ekstrehub

# ── Mail accounts ─────────────────────────────────────────────
# Mail accounts are added through the app UI (Settings → Mail & Sync).
# The legacy single-account env-var mode is still supported:
MAIL_INGESTION_ENABLED=true
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=your-mail@gmail.com
# IMAP_PASSWORD=your-16-char-app-password
# IMAP_MAILBOX=INBOX
# IMAP_UNSEEN_ONLY=true
# IMAP_FETCH_LIMIT=20

# ── Gmail OAuth (optional) ────────────────────────────────────
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=

# ── AI / LLM Parser ───────────────────────────────────────────
# These are seeded into app_settings.json on first run.
# After that, use the AI Parser settings page in the UI.
# LLM_API_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_SECONDS=120
